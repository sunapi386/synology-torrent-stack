# VPN Provider (surfshark, mullvad, nordvpn, pia, etc.)
# See https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
VPN_PROVIDER=surfshark

# WireGuard credentials from your VPN provider
WIREGUARD_PRIVATE_KEY=your-wireguard-private-key-here
WIREGUARD_ADDRESSES=10.14.0.2/16

# VPN server location
SERVER_CITY=San Jose

# Timezone
TZ=America/Los_Angeles

# Synology user/group IDs (run `id` via SSH to find yours)
PUID=1027
PGID=100

# Where downloads are saved (should be accessible by Plex)
DOWNLOAD_DIR=/volume1/public-media/Downloads

# qBittorrent Web UI port
WEBUI_PORT=8080
